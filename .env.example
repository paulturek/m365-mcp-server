# ── Azure AD App Registration ──────────────────────────────────────
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-app-client-secret
AZURE_TENANT_ID=your-tenant-id

# ── OAuth Web Flow (NEW — replaces device-code flow) ──────────────
# Redirect URI registered in Azure AD → Platform: Web
OAUTH_REDIRECT_URI=https://your-app.up.railway.app/auth/callback

# Fernet key for at-rest token encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Token store backend: "file" (Option A) or "pg" (Option B)
TOKEN_STORE_BACKEND=file

# Option A — file path for encrypted token store
TOKEN_STORE_PATH=/app/data/tokens.enc

# Option B — PostgreSQL connection (also used for PgTokenStore)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── MCP Server Auth ───────────────────────────────────────────────
# Bearer token for POST /mcp (leave blank for open/dev mode)
MCP_BEARER_TOKEN=

# ── Server ────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=INFO

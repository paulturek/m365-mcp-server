# =============================================================================
# M365 MCP Server Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Azure AD App Registration (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from: Azure Portal > Microsoft Entra ID > App registrations

# Application (client) ID from your app registration
M365_CLIENT_ID=your-client-id-here

# Directory (tenant) ID - use 'common' for multi-tenant or your specific tenant ID
M365_TENANT_ID=common

# -----------------------------------------------------------------------------
# Optional: Confidential Client (for server-to-server auth)
# -----------------------------------------------------------------------------
# Only needed if using client credentials flow instead of device code
# M365_CLIENT_SECRET=your-client-secret-here

# -----------------------------------------------------------------------------
# Optional: Token Cache Configuration
# -----------------------------------------------------------------------------
# Custom path for token cache file (default: ~/.m365-mcp/token_cache.bin)
# M365_TOKEN_CACHE_PATH=/path/to/token_cache.bin

# Custom encryption key for token cache (default: auto-generated)
# Must be a valid Fernet key (base64-encoded 32-byte key)
# M365_CACHE_ENCRYPTION_KEY=your-fernet-key-here
